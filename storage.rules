rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /evidence/{scheduleId}/{role}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /payments/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == "alexanderarcedaniel@gmail.com");
    }
  }
}
