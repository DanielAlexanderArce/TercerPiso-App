rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - username: string (optional)
    //   - name: string (required)
    //   - role: string (required, ADMIN|INQUILINO)
    //   - roomNumber: string (optional)
    //   - createdAt: number (required)
    //
    // Collection: payments
    // Document ID: {paymentId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - month: string (required, YYYY-MM)
    //   - amount: number (required)
    //   - status: string (required, PENDING|COMPLETED)
    //   - evidenceUrl: string (optional)
    //   - createdAt: number (required)
    //   - updatedAt: number (required)
    //
    // Collection: schedules
    // Document ID: {scheduleId}
    // Fields:
    //   - id: string (required)
    //   - weekStart: string (required, date)
    //   - weekEnd: string (required, date)
    //   - assignments: list (required)
    //   - createdAt: number (required)
    //   - updatedAt: number (optional)
    //
    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - title: string (required)
    //   - message: string (required)
    //   - type: string (required, INFO|WARNING|SUCCESS)
    //   - read: bool (required)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == userId.lower()));
    }

    function isDocOwner() {
      return isAuthenticated() && resource != null && (resource.data.uid == request.auth.uid || ('email' in request.auth.token && request.auth.token.email != null && 'email' in resource.data && resource.data.email != null && resource.data.email.lower() == request.auth.token.email.lower()));
    }

    function isAdmin() {
      return isAuthenticated() && (
          request.auth.uid == "S1zwiDJYZ3h4KbJIOqPZYOEGI423" ||
          request.auth.uid == "oHLPQPksmhYI27b4mqCT2XIuwNz2" ||
          (request.auth.token.email != null && (
            request.auth.token.email.lower() == "alexanderarcedaniel@gmail.com" ||
            request.auth.token.email.lower() == "pedro@gmail.com" ||
            request.auth.token.email.lower() == "admin@admin.com"
          ))
        );
    }

    // Alias for backward compatibility if needed, but we'll use isAdmin everywhere
    function isUserAdmin() {
      return isAdmin();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'createdAt']) &&
             data.keys().hasOnly(['uid', 'email', 'username', 'name', 'role', 'createdAt']) &&
             (!('uid' in data) || (data.uid is string && data.uid.size() < 128)) &&
             data.email is string && data.email.size() < 100 &&
             (!('username' in data) || (data.username is string && data.username.size() < 50)) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['ADMIN', 'INQUILINO'] &&
             data.createdAt is number;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['userId', 'userName', 'month', 'amount', 'status', 'createdAt', 'updatedAt']) &&
             data.keys().hasOnly(['id', 'userId', 'userName', 'month', 'paymentDate', 'amount', 'status', 'evidenceUrl', 'createdAt', 'updatedAt']) &&
             (!('id' in data) || (data.id is string && data.id.size() < 128)) &&
             data.userId is string && data.userId.size() < 128 &&
             data.userName is string && data.userName.size() < 100 &&
             data.month is string && data.month.matches('^\\d{4}-\\d{2}$') &&
             (!('paymentDate' in data) || (data.paymentDate is string && data.paymentDate.matches('^\\d{4}-\\d{2}-\\d{2}$'))) &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['PENDING', 'COMPLETED', 'REJECTED'] &&
             (!('evidenceUrl' in data) || (data.evidenceUrl == null || (data.evidenceUrl is string && data.evidenceUrl.size() < 2000000))) &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['role', 'status']) &&
             data.keys().hasOnly(['role', 'status', 'evidenceUrls', 'completedAt', 'verified']) &&
             data.role in ['Limpieza de Baño', 'Limpieza de Pasadizo y Lavandería'] &&
             data.status in ['PENDING', 'COMPLETED', 'REJECTED'] &&
             (!('evidenceUrls' in data) || (data.evidenceUrls is list && data.evidenceUrls.size() <= 5)) &&
             (!('completedAt' in data) || (data.completedAt is number)) &&
             (!('verified' in data) || (data.verified is bool));
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['weekStart', 'weekEnd', 'assignedUserId', 'assignments', 'createdAt']) &&
             data.keys().hasOnly(['id', 'weekStart', 'weekEnd', 'assignedUserId', 'assignedUserName', 'assignments', 'createdAt', 'updatedAt']) &&
             (!('id' in data) || (data.id is string && data.id.size() < 128)) &&
             data.weekStart is string && data.weekStart.size() < 50 &&
             data.weekEnd is string && data.weekEnd.size() < 50 &&
             data.assignedUserId is string && data.assignedUserId.size() < 128 &&
             (!('assignedUserName' in data) || (data.assignedUserName is string && data.assignedUserName.size() < 100)) &&
             data.assignments is list && data.assignments.size() <= 5 &&
             data.createdAt is number &&
             (!('updatedAt' in data) || (data.updatedAt is number));
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.keys().hasOnly(['id', 'userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             (!('id' in data) || (data.id is string && data.id.size() < 128)) &&
             data.userId is string && data.userId.size() < 128 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.type in ['INFO', 'WARNING', 'SUCCESS', 'ERROR'] &&
             data.read is bool &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.resource.data.uid == request.auth.uid || ('email' in request.auth.token && request.auth.token.email != null && request.resource.data.email.lower() == request.auth.token.email.lower()));
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) || isDocOwner()));
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (isAuthenticated() && isValidPayment(request.resource.data) && (request.auth.uid == request.resource.data.userId || ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == request.resource.data.userId.lower())));
      allow update: if isAdmin() || (isAuthenticated() && isValidPayment(request.resource.data) && (request.auth.uid == resource.data.userId || ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == resource.data.userId.lower())));
      allow delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && isValidSchedule(request.resource.data) && (request.auth.uid == resource.data.assignedUserId || ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == resource.data.assignedUserId.lower())));
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.userId || ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == resource.data.userId.lower()));
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && isValidNotification(request.resource.data) && (isAdmin() || request.auth.uid == resource.data.userId || ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == resource.data.userId.lower()));
      allow delete: if isAdmin();
    }
  }
}
